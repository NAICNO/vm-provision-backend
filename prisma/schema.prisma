generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserActivity {
  activityId   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("activity_id")
  userId       String?   @db.Uuid @map("user_id")
  vmId         String?   @db.Uuid @map("vm_id")
  activityType String    @map("activity_type")
  description  String?
  timestamp    DateTime? @default(now()) @db.Timestamp(6)

  @@map("user_activity")
}

model UserProfile {
  userId        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("user_id")
  email         String           @unique
  username      String           @unique
  password      String
  firstName     String           @map("first_name")
  lastName      String           @map("last_name")
  userType      String           @default("User") @map("user_type")
  createdAt     DateTime?        @default(now()) @db.Timestamp(6) @map("created_at")
  updatedAt     DateTime?        @default(now()) @db.Timestamp(6) @map("updated_at")
  virtualMachines VirtualMachine[]

  @@map("user_profile")
}

model VirtualMachine {
  vmId          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("vm_id")
  userId        String?        @db.Uuid @map("user_id")
  templateId    String?        @db.Uuid @map("template_id")
  vmName        String         @map("vm_name")
  ipv4Address   String?        @map("ipv4_address")
  ipv6Address   String?        @map("ipv6_address")
  status        String?        @map("status")
  createdAt     DateTime?      @default(now()) @db.Timestamp(6) @map("created_at")
  updatedAt     DateTime?      @default(now()) @db.Timestamp(6) @map("updated_at")
  vmTemplate    VmTemplate?    @relation(fields: [templateId], references: [templateId], onUpdate: NoAction)
  userProfile   UserProfile?   @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: NoAction)
  vmEvents      VmEvent[]

  @@map("virtual_machine")
}

model VmEvent {
  eventId        String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("event_id")
  vmId           String?         @db.Uuid @map("vm_id")
  eventType      String          @map("event_type")
  description    String?
  timestamp      DateTime?       @default(now()) @db.Timestamp(6)
  virtualMachine VirtualMachine? @relation(fields: [vmId], references: [vmId], onDelete: Cascade, onUpdate: NoAction)

  @@map("vm_event")
}

model VmTemplate {
  templateId      String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("template_id")
  templateName    String           @unique @map("template_name")
  cpu             Int              @map("cpu")
  ram             Int              @map("ram")
  storage         Int              @map("storage")
  os              String           @map("os")
  description     String?          @map("description")
  createdAt       DateTime?        @default(now()) @db.Timestamp(6) @map("created_at")
  updatedAt       DateTime?        @default(now()) @db.Timestamp(6) @map("updated_at")
  virtualMachines VirtualMachine[]

  @@map("vm_template")
}
