PORT=3000
AUTH_API_KEY_SECRET=<generate-a-uuid>
SESSION_SECRET=<generate-a-random-base64-string>
SOCKET_NAMESPACE_VM=/vm
DATABASE_URL_GCP=postgresql://user:password@host:5432/vm_management_db?schema=public
RABBITMQ_URL_GCP=amqp://user:password@rabbitmq-host:5672
REDIS_URL_GCP=redis://localhost:6379
REDIS_PASSWORD=<your-redis-password>
CLOUD_INIT_CALLBACK_BASE_URL=http://<your-callback-host>/go
VM_QUOTA_PER_USER=4
SIGMA_DISCOVERY_URL=<your-oidc-discovery-url>
SIGMA_CLIENT_ID=<your-oidc-client-id>
SIGMA_CLIENT_SECRET=<your-oidc-client-secret>
SIGMA_REDIRECT_URI=http://localhost:3000/api/auth/callback
SIGMA_LOGOUT_REDIRECT_URI=http://localhost:8080
AUTH_POST_LOGIN_REDIRECT_URL=http://localhost:8080/kcauth/callback
