{
  "name": "vm-provision-backend",
  "version": "1.0.0",
  "description": "Backend - VM Provisioning",
  "main": "index.ts",
  "scripts": {
    "build": "npx tsc && yarn sentry:sourcemaps",
    "start": "node dist/index.js",
    "dev": "concurrently \"npx tsc -w\" \"nodemon dist/index.js\"",
    "prod": "NODE_ENV=production node dist/index.js",
    "test": "jest",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org uio-naic --project vm-backend ./dist && sentry-cli sourcemaps upload --org uio-naic --project vm-backend ./dist"
  },
  "author": "Ashen Wijesiri",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "@sentry/cli": "^2.33.1",
    "@sentry/node": "^8.26.0",
    "@sentry/profiling-node": "^8.26.0",
    "amqplib": "^0.10.4",
    "axios": "^1.7.5",
    "connect-redis": "^7.1.1",
    "cors": "^2.8.5",
    "croner": "^8.1.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "pg": "^8.12.0",
    "redis": "^4.7.0",
    "socket.io": "^4.7.5",
    "sshpk": "^1.18.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.6",
    "@types/sshpk": "^1.17.4",
    "@typescript-eslint/eslint-plugin": "^6.8.0",
    "@typescript-eslint/parser": "^6.8.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.51.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prisma": "^5.18.0",
    "prisma-dbml-generator": "^0.12.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.5.4"
  },
