    "cors": "^2.8.5",
    "croner": "^9.0.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-session": "^1.18.1",
    "express-winston": "^4.2.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "openid-client": "^5.7.0",
