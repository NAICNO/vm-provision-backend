{
  "name": "vm-provision-backend",
  "version": "1.0.0",
  "description": "Backend - VM Provisioning",
  "main": "index.ts",
  "scripts": {
    "build": "npx tsc && yarn sentry:sourcemaps",
    "start": "node dist/index.js",
    "dev": "concurrently \"npx tsc -w\" \"nodemon dist/index.js\"",
    "prod": "NODE_ENV=production node dist/index.js",
    "test": "jest",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org uio-naic --project vm-backend ./dist && sentry-cli sourcemaps upload --org uio-naic --project vm-backend ./dist"
  },
  "author": "Ashen Wijesiri",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "@sentry/cli": "^2.53.0",
    "@sentry/node": "^10.12.0",
    "@sentry/profiling-node": "^10.12.0",
    "amqplib": "^0.10.9",
    "axios": "1.12.2",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "croner": "^9.1.0",
    "dotenv": "^17.2.2",
    "express": "^4.21.2",
    "express-session": "^1.18.2",
    "express-winston": "^4.2.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.2.0",
    "openid-client": "^6.8.0",
    "pg": "^8.16.3",
    "redis": "^5.8.2",
    "socket.io": "^4.8.1",
    "sshpk": "^1.18.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.15.5",
    "@types/sshpk": "^1.17.4",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.35.0",
    "jest": "^30.1.3",
    "nodemon": "^3.1.10",
    "prisma": "^6.16.2",
    "prisma-dbml-generator": "^0.12.0",
    "ts-jest": "^29.4.3",
    "typescript": "^5.9.2"
  },
  "packageManager": "yarn@4.9.1"
}
